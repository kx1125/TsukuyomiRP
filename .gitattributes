* text=auto

*.cs text eol=lf
*.hlsl text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.json text eol=lf
*.md text eol=lf
*.meta text eol=lf
*.asset text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.exr binary
*.dds binary
*.fbx binary
*.dll binary

# Large binary assets distributed with package samples.
Samples~/**/*.png filter=lfs diff=lfs merge=lfs -text
Samples~/**/*.fbx filter=lfs diff=lfs merge=lfs -text
Samples~/**/*.bytes filter=lfs diff=lfs merge=lfs -text
